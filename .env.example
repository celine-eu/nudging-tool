
DATABASE_URL=postgresql+asyncpg://postgres:securepassword123@host.docker.internal:15432/nudging

DEFAULT_LANG=it
MAX_PER_DAY_DEFAULT=3

VAPID_PUBLIC_KEY=your key
VAPID_PRIVATE_KEY=your key
VAPID_SUBJECT=your subject

# SMTP -- Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=no-reply@example.com
